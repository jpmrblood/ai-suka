---
import { SITE_TITLE } from "../consts";
import { Menu, X } from 'lucide-astro';
import ThemeToggle from './ThemeToggle.astro';
import SearchButton from './SearchButton.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 p-3 md:p-4">
	<div class="navbar max-w-4xl mx-auto px-4 md:px-6 rounded-full shadow-lg border border-white/20" style="background: inherit; background-color: rgba(255, 255, 255, .3); backdrop-filter: blur(5px);">
		<div class="navbar-start">
			<a href={`${import.meta.env.BASE_URL}/`} class="text-lg md:text-xl font-bold hover:text-primary transition-colors">
				{SITE_TITLE}
			</a>
		</div>

		<div class="navbar-center hidden lg:flex">
			<ul class="menu menu-horizontal px-1 gap-1">
				<li><a href={`${import.meta.env.BASE_URL}/`} class="hover:text-primary rounded-full">Home</a></li>
				<li><a href={`${import.meta.env.BASE_URL}/categories/`} class="hover:text-primary rounded-full">Categories</a></li>
				<li><a href={`${import.meta.env.BASE_URL}/about`} class="hover:text-primary rounded-full">About</a></li>
			</ul>
		</div>

		<div class="navbar-end gap-1">
			<SearchButton />
			<ThemeToggle />

			<div class="dropdown dropdown-end lg:hidden">
				<div tabindex="0" role="button" class="btn btn-ghost btn-circle" aria-label="Menu">
					<Menu class="w-5 h-5" />
				</div>
				<ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-lg bg-base-100 rounded-box w-52">
					<li><a href={`${import.meta.env.BASE_URL}/`}>Home</a></li>
					<li><a href={`${import.meta.env.BASE_URL}/categories/`}>Categories</a></li>
					<li><a href={`${import.meta.env.BASE_URL}/about`}>About</a></li>
				</ul>
			</div>
		</div>
	</div>
</header>
