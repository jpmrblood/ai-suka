---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingTime from '../components/ReadingTime.astro';
import { calculateReadingTime } from '../utils/readingTime';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import fs from 'node:fs';
import path from 'node:path';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featuredPost = allPosts[0];
const remainingPosts = allPosts.slice(1);

function getReadingTime(postId: string): number {
	const mdPath = path.join('./src/content/blog', `${postId}.md`);
	const mdxPath = path.join('./src/content/blog', `${postId}.mdx`);
	let content = '';
	
	try {
		if (fs.existsSync(mdPath)) {
			content = fs.readFileSync(mdPath, 'utf-8');
		} else if (fs.existsSync(mdxPath)) {
			content = fs.readFileSync(mdxPath, 'utf-8');
		}
		content = content.replace(/^---[\s\S]*?---/, '').trim();
		return calculateReadingTime(content);
	} catch {
		return 5;
	}
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<meta name="base-url" content={import.meta.env.BASE_URL} />
		<style>
			.hero-container {
				min-height: 70vh;
				background-color: var(--color-base-300);
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				position: relative;
			}

			.hero-overlay-bg {
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: rgba(0, 0, 0, 0.5);
				z-index: 1;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 70vh;
				color: white;
				padding: 6rem 1.5rem;
			}

			@media (min-width: 768px) {
				.hero-container,
				.hero-content {
					min-height: 100vh;
				}
			}

			@media (max-width: 768px) {
				.hero-content {
					padding: 5rem 1rem;
				}
			}
		</style>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<Header />

		<!-- Full page hero background -->
		{featuredPost.data.heroImage ? (
			<div class="hero-container" style={`background-image: url('${featuredPost.data.heroImage.src}');`}>
				<div class="hero-overlay-bg"></div>
				<div class="hero-content">
					<div class="max-w-4xl mx-auto">
						<h1 class="mb-6 text-3xl md:text-5xl font-bold leading-tight">
							{featuredPost.data.title}
						</h1>
						<p class="mb-6 text-base md:text-xl leading-relaxed opacity-90">
							{featuredPost.data.description}
						</p>
						<div class="flex flex-wrap gap-4 items-center">
							<a href={`${import.meta.env.BASE_URL}/${featuredPost.id}/`} class="btn btn-primary btn-lg">
								Read Full Article
							</a>
							<ReadingTime minutes={getReadingTime(featuredPost.id)} />
						</div>
					</div>
				</div>
			</div>
		) : (
			<div class="hero-container">
				<div class="hero-content">
					<div class="max-w-4xl mx-auto text-center">
						<h1 class="mb-6 text-3xl md:text-5xl font-bold leading-tight text-base-content">
							{featuredPost.data.title}
						</h1>
						<p class="mb-6 text-base md:text-xl leading-relaxed text-base-content/80">
							{featuredPost.data.description}
						</p>
						<div class="flex flex-wrap gap-4 items-center justify-center">
							<a href={`${import.meta.env.BASE_URL}/${featuredPost.id}/`} class="btn btn-primary btn-lg">
								Read Full Article
							</a>
							<ReadingTime minutes={getReadingTime(featuredPost.id)} />
						</div>
					</div>
				</div>
			</div>
		)}

		<!-- Articles Section -->
		<main id="main-content" class="container mx-auto px-4 py-16 max-w-6xl">
			<h2 class="text-3xl font-bold mb-8 text-center">Latest Articles</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
				{remainingPosts.map((post) => (
					<article class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-300">
						{post.data.heroImage && (
							<figure class="px-4 pt-4">
								<a href={`${import.meta.env.BASE_URL}/${post.id}/`}>
									<Image
										width={400}
										height={200}
										src={post.data.heroImage}
										alt={post.data.title}
										class="rounded-xl w-full h-48 object-cover"
									/>
								</a>
							</figure>
						)}
						<div class="card-body">
							<h3 class="card-title text-xl mb-2">
								<a href={`${import.meta.env.BASE_URL}/${post.id}/`} class="hover:text-primary transition-colors">
									{post.data.title}
								</a>
							</h3>
							<div class="flex flex-wrap gap-2 text-sm text-base-content/80 mb-3">
								<span><FormattedDate date={post.data.pubDate} /></span>
								<span>·</span>
								<ReadingTime minutes={getReadingTime(post.id)} />
							</div>
							<p class="text-base-content/80 leading-relaxed mb-4 line-clamp-3">
								{post.data.description}
							</p>
							<div class="flex flex-wrap gap-1 mb-3">
								{post.data.categories?.slice(0, 2).map((category: string) => (
									<a
										href={`${import.meta.env.BASE_URL}/categories/${category}/`}
										class="badge badge-sm badge-outline hover:badge-primary transition-colors"
									>
										{category}
									</a>
								))}
							</div>
							<div class="card-actions justify-end">
								<a href={`${import.meta.env.BASE_URL}/${post.id}/`} class="btn btn-primary btn-sm">
									Read more
								</a>
							</div>
						</div>
					</article>
				))}
			</div>
		</main>

		<BackToTop />
		<Footer />
	</body>
</html>
